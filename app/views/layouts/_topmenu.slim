nav.sticky.top-0.z-50.bg-white.border-b.border-gray-200[data-controller="toggle"]
  .max-w-full.mx-auto.px-4.sm:px-6
    .flex.items-center.justify-between.h-14
      .flex.items-center
        = link_to root_url, class: 'text-lg font-semibold text-gray-900 no-underline' do
          = render 'logo'
      / Desktop nav
      .hidden.lg:flex.items-center.space-x-1
        = navbar_link_to OpenbillAccount.model_name.human(count: 2), accounts_path
        = navbar_link_to OpenbillTransaction.model_name.human(count: 2), transactions_path
        = navbar_link_to OpenbillCategory.model_name.human(count: 2), categories_path
        = navbar_link_to OpenbillPolicy.model_name.human(count: 2), policies_path
      .hidden.lg:flex.items-center.ml-4
        - other_locale = (I18n.available_locales - [I18n.locale]).first
        = button_to other_locale.to_s.upcase, locale_path(locale: other_locale), method: :put, class: 'px-2 py-1 text-sm text-gray-500 hover:text-gray-900 font-medium'
      / Mobile menu button
      .lg:hidden
        button.inline-flex.items-center.justify-center.p-2.rounded-md.text-gray-600.hover:text-gray-900.hover:bg-gray-100[type="button" data-action="click->toggle#toggle" aria-expanded="false" aria-controls="mobile-menu" aria-label="Toggle navigation"]
          svg.h-6.w-6[xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"]
            path[stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"]
    / Mobile menu
    #mobile-menu.hidden.lg:hidden.border-t.border-gray-200.py-2[data-toggle-target="content"]
      .flex.flex-col.space-y-1
        = navbar_link_to OpenbillAccount.model_name.human(count: 2), accounts_path
        = navbar_link_to OpenbillTransaction.model_name.human(count: 2), transactions_path
        = navbar_link_to OpenbillCategory.model_name.human(count: 2), categories_path
        = navbar_link_to OpenbillPolicy.model_name.human(count: 2), policies_path
        .pt-2.border-t.border-gray-100.mt-2
          - other_locale = (I18n.available_locales - [I18n.locale]).first
          = button_to other_locale.to_s.upcase, locale_path(locale: other_locale), method: :put, class: 'px-3 py-2 text-sm text-gray-500 hover:text-gray-900 font-medium'
